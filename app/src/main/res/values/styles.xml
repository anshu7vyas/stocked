<resources>

    <!-- Splash (Android 12+ SplashScreen API, backported by core-splashscreen). -->
    <style name="Theme.Stocked.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Stocked</item>
    </style>

    <!-- Compose owns all theming; this is just the window scaffold. -->
    <style name="Theme.Stocked" parent="android:Theme.Material.Light.NoActionBar" />

</resources>
